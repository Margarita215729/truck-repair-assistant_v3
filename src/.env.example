# Пример файла переменных окружения для Truck Diagnostic AI
# Скопируйте этот файл в .env.local и заполните ваши реальные значения

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# API Keys
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GITHUB_TOKEN=your_github_token_for_ai_models_here

# Environment
NODE_ENV=production

# Optional: Additional API Keys for future features
# TOWING_SERVICE_API_KEY=your_towing_service_api_key_here
# PARTS_DATABASE_API_KEY=your_parts_database_api_key_here
# TWILIO_ACCOUNT_SID=your_twilio_sid_here
# TWILIO_AUTH_TOKEN=your_twilio_token_here

# Примечания:
# - Все переменные с префиксом VITE_ будут доступны в браузере
# - SUPABASE_SERVICE_ROLE_KEY и GITHUB_TOKEN используются только на сервере
# - При деплое на Vercel, добавьте эти переменные в Project Settings > Environment Variables