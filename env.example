# Truck Repair Assistant - Environment Variables Example
# Copy this file to .env.local and fill in your actual API keys
# NEVER commit .env.local to git!

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Maps API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# GitHub API Token (for GitHub Models)
VITE_GITHUB_API_TOKEN=your_github_api_token_here

# Environment
VITE_ENVIRONMENT=development

# Example values (DO NOT USE IN PRODUCTION):
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# VITE_GOOGLE_MAPS_API_KEY=AIzaSyBvOkBw...
# VITE_GITHUB_API_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx





