# AI-Powered Truck Diagnostic System v2
# Environment Variables Configuration

# ===========================================
# GOOGLE MAPS API CONFIGURATION
# ===========================================
# Required for map functionality and location services
# Get your API key from: https://console.cloud.google.com/apis/credentials

# Vite Environment Variables (for development)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Next.js Environment Variables (for compatibility)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Standard Environment Variables (for production)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Required for database operations and authentication
# Get your keys from: https://supabase.com/dashboard

# Vite Environment Variables (for development)
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Standard Environment Variables (for production)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Service Role Key (for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ===========================================
# GITHUB INTEGRATION
# ===========================================
# Required for AI model training and GitHub Models integration
# Get your token from: https://github.com/settings/tokens

MODELS_GITHUB_TOKEN_TOKEN=your_github_personal_access_token_here

# ===========================================
# DEVELOPMENT CONFIGURATION
# ===========================================
# Node.js environment
NODE_ENV=development

# ===========================================
# USAGE INSTRUCTIONS
# ===========================================
# 1. Copy this file to .env.local for local development
# 2. Copy this file to .env for production deployment
# 3. Replace all "your_*_here" values with actual keys
# 4. Never commit .env files to version control
# 5. For Vercel deployment, add these variables in Vercel dashboard

# ===========================================
# VARIABLE PRIORITY ORDER
# ===========================================
# The application checks for environment variables in this order:
# 1. VITE_* variables (for Vite development)
# 2. NEXT_PUBLIC_* variables (for Next.js compatibility)
# 3. Standard variables (for production)
# 4. Fallback values (hardcoded in safe-env.ts)

# ===========================================
# SECURITY NOTES
# ===========================================
# - Keep your API keys secure
# - Use different keys for development and production
# - Regularly rotate your keys
# - Monitor API usage to prevent abuse
# - Set up proper API key restrictions in Google Cloud Console
