# Truck Repair Assistant v3 — Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase (auth + data storage)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI / LLM (GitHub Models API)
VITE_GITHUB_TOKEN=github_pat_your-token-here

# Google Maps (for service locator)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# YouTube Data API (for repair video search)
VITE_YOUTUBE_API_KEY=your-youtube-api-key-here
