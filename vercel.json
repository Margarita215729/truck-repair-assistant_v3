{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/stripe-webhook.js": {
      "maxDuration": 30
    },
    "api/ai-proxy.js": {
      "maxDuration": 60
    },
    "api/gemini-proxy.js": {
      "maxDuration": 60
    },
    "api/parts/search.js": {
      "maxDuration": 30
    },
    "api/telematics/oauth-start.js": {
      "maxDuration": 10
    },
    "api/telematics/oauth-callback.js": {
      "maxDuration": 30
    },
    "api/telematics/truck-state-snapshot.js": {
      "maxDuration": 60
    },
    "api/webhooks/samsara.js": {
      "maxDuration": 30
    },
    "api/webhooks/motive.js": {
      "maxDuration": 30
    }
  }
}
