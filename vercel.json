{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/ai-proxy.js": {
      "maxDuration": 60
    },
    "api/gemini-proxy.js": {
      "maxDuration": 60
    },
    "api/parts/search.js": {
      "maxDuration": 30
    },
    "api/telematics/oauth-start.js": {
      "maxDuration": 10
    },
    "api/telematics/oauth-callback.js": {
      "maxDuration": 30
    },
    "api/telematics/truck-state-snapshot.js": {
      "maxDuration": 60
    },
    "api/webhooks/samsara.js": {
      "maxDuration": 30
    },
    "api/webhooks/motive.js": {
      "maxDuration": 30
    },
    "api/webhooks/geotab.js": {
      "maxDuration": 30
    },
    "api/webhooks/verizonconnect.js": {
      "maxDuration": 30
    },
    "api/webhooks/omnitracs.js": {
      "maxDuration": 30
    },
    "api/telematics/token-refresh.js": {
      "maxDuration": 30
    },
    "api/telematics/credential-connect.js": {
      "maxDuration": 30
    },
    "api/telematics/geotab-feed.js": {
      "maxDuration": 60
    },
    "api/telematics/vehicles.js": {
      "maxDuration": 15
    }
  },
  "crons": [
    {
      "path": "/api/telematics/token-refresh",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/telematics/geotab-feed",
      "schedule": "*/15 * * * *"
    }
  ]
}
