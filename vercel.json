{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/stripe-webhook.js": {
      "maxDuration": 30
    },
    "api/ai-proxy.js": {
      "maxDuration": 60
    }
  }
}
